{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://namengine.com/schemas/name-evaluation-fixture-v1.json",
  "title": "Namengine Name Evaluation Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id", "schema_version", "vertical", "title", "description", "intake",
    "expected_naming_territories", "desired_qualities", "prohibited_qualities",
    "acceptance_criteria", "regression_notes", "tags", "enabled"
  ],
  "properties": {
    "fixture_id": {"type": "string", "minLength": 1, "maxLength": 500},
    "schema_version": {"const": "name-evaluation-fixture-v1"},
    "vertical": {"type": "string", "minLength": 1},
    "title": {"type": "string", "maxLength": 500},
    "description": {"type": "string", "maxLength": 500},
    "intake": {"type": "object"},
    "expected_naming_territories": {"$ref": "#/$defs/stringList"},
    "desired_qualities": {"$ref": "#/$defs/stringList"},
    "prohibited_qualities": {"$ref": "#/$defs/stringList"},
    "reference_candidates": {"$ref": "#/$defs/stringList"},
    "rejection_candidates": {"$ref": "#/$defs/stringList"},
    "regression_notes": {"type": "string", "maxLength": 500},
    "tags": {"$ref": "#/$defs/stringList"},
    "enabled": {"type": "boolean"},
    "acceptance_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_normalized_score", "criteria"],
      "properties": {
        "minimum_normalized_score": {"type": "number", "minimum": 0, "maximum": 1},
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["criterion", "weight"],
            "properties": {
              "criterion": {"type": "string", "minLength": 1},
              "weight": {"type": "number", "exclusiveMinimum": 0},
              "required": {"type": "boolean"},
              "parameters": {"type": "object"}
            }
          }
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "maxItems": 100,
      "items": {"type": "string", "maxLength": 500}
    }
  }
}
