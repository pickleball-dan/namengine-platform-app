# OpenAI generation
OPENAI_API_KEY=
NAMENGINE_OPENAI_MODEL=gpt-4.1-mini
NAMENGINE_IMAGE_MODEL=gpt-image-1-mini
NAMENGINE_IMAGE_SIZE=1024x1024
# Optional in local development. Set this to a persistent disk path in production.
NAMENGINE_GENERATED_IMAGE_DIR=
# Generated PNG files older than this are removed when a new image is created.
NAMENGINE_IMAGE_RETENTION_DAYS=30
# Per-vertical image-generation kill switches (1 disables image creation).
NAMENGINE_DISABLE_BABY_IMAGES=0
NAMENGINE_DISABLE_PET_IMAGES=0
NAMENGINE_DISABLE_BUSINESS_IMAGES=0

# Optional: direct Google Sheets upload for engine audit runs
# Reuses the old smoke-test sheet id if GOOGLE_ENGINE_AUDIT_SHEET_ID is omitted.
GOOGLE_ENGINE_AUDIT_SHEET_ID=
GOOGLE_ENGINE_AUDIT_WORKSHEET=Engine Audit
# Prefer a local JSON file path over pasting the full secret JSON into .env.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=C:\\path\\to\\service-account.json\n# Older inline option still works if needed:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
