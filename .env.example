# OpenAI generation
OPENAI_API_KEY=
NAMENGINE_OPENAI_MODEL=gpt-4.1-mini

# Optional: direct Google Sheets upload for engine audit runs
# Reuses the old smoke-test sheet id if GOOGLE_ENGINE_AUDIT_SHEET_ID is omitted.
GOOGLE_ENGINE_AUDIT_SHEET_ID=
GOOGLE_ENGINE_AUDIT_WORKSHEET=Engine Audit
# Prefer a local JSON file path over pasting the full secret JSON into .env.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=C:\\path\\to\\service-account.json\n# Older inline option still works if needed:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
